# ============================================================
# 终极稳定版 x86_64 OpenWrt
# 核心：CUPS最新全驱动 + SSR-Plus纯净版 + ksmbd自动共享
# 已做防翻车精简、禁用循环依赖、不冗余、不报错
# ============================================================

# ---------- 目标系统 x86_64 单设备纯净编译 ----------
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_PER_DEVICE_ROOTFS=n

# ---------- 镜像格式：只保留常用稳定格式，减少编译耗时和体积 ----------
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=n
CONFIG_ISO_IMAGES=n
CONFIG_VMDK_IMAGES=n
CONFIG_TARGET_IMAGES_GZIP=y

# ---------- 全局优化 个人编译不用官方BUILDBOT校验 ----------
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
CONFIG_AUTOREMOVE=y
# CONFIG_BUILDBOT is not set

# ---------- 系统核心 基础必备 ----------
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_openssh-sftp-server=y

# ---------- USB/存储/打印机 全支持 ----------
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs=y

# ---------- 基础网络 IPv6/UPnP/DDNS 全套稳定 ----------
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_odhcpd=y                      # 确保这一行存在，我们保留完整的 odhcpd
# CONFIG_PACKAGE_odhcpd-ipv6only is not set  # 禁用冲突的轻量版
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y

# ---------- CUPS 2.4 全套 + 完整打印驱动 ----------
CONFIG_PACKAGE_cups=y
CONFIG_PACKAGE_cups-filters=y
CONFIG_PACKAGE_cups-bjnp=y
CONFIG_PACKAGE_libusb-1.0=y
CONFIG_PACKAGE_avahi-daemon=y
CONFIG_PACKAGE_avahi-utils=y
CONFIG_PACKAGE_dbus=y
CONFIG_PACKAGE_foomatic-db=y
CONFIG_PACKAGE_foomatic-db-engine=y
CONFIG_PACKAGE_gutenprint=y

# ---------- ksmbd 局域网低占用共享 ----------
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_ksmbd-server=y

# ---------- SSR-Plus 纯净版 保留Xray ----------
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y

# ---------- 基础磁盘工具 ----------
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_bash=y

# ---------- 禁用硬件监控 减少内存占用 ----------
# CONFIG_PACKAGE_kmod-hwmon-core is not set

# ---------- 强制禁用循环依赖插件 从根源杜绝编译收尾报错 ----------
CONFIG_PACKAGE_luci-app-fchomo=n
CONFIG_PACKAGE_nikki=n
